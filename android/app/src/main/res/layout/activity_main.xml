<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/header_dark"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🤖 Younes AI"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="@color/white" />

    </LinearLayout>

    <!-- أزرار النماذج -->
    <HorizontalScrollView
        android:id="@+id/scroll_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@color/header_dark"
        app:layout_constraintTop_toBottomOf="@id/header">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_llama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🦙 Llama 4"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/chip_selector"
                app:chipStrokeColor="@color/green_accent"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_deepseek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐋 DeepSeek"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/chip_selector"
                app:chipStrokeColor="@color/green_accent"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_gpt5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ GPT-5"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/chip_selector"
                app:chipStrokeColor="@color/green_accent"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_compare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔀 قارن"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/chip_selector"
                app:chipStrokeColor="@color/compare_color"
                app:chipStrokeWidth="1dp" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- تبويبات المقارنة — تظهر فقط عند اختيار قارن -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@color/header_dark"
        app:tabTextColor="@color/hint_color"
        app:tabSelectedTextColor="@color/green_accent"
        app:tabIndicatorColor="@color/green_accent"
        app:layout_constraintTop_toBottomOf="@id/scroll_chips" />

    <!-- منطقة المحادثة العادية -->
    <FrameLayout
        android:id="@+id/layout_normal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tab_layout"
        app:layout_constraintBottom_toTopOf="@id/input_layout">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

    </FrameLayout>

    <!-- منطقة المقارنة — 3 شاشات بالسحب -->
    <FrameLayout
        android:id="@+id/layout_compare"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tab_layout"
        app:layout_constraintBottom_toTopOf="@id/input_layout">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- Input Area -->
    <LinearLayout
        android:id="@+id/input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/header_dark"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="اكتب رسالتك..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="@color/white"
            android:textColorHint="@color/hint_color"
            android:textSize="15sp"
            android:layoutDirection="rtl" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_send_button"
            android:src="@android:drawable/ic_menu_send"
            android:tint="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
